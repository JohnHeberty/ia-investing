{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ia-investing:agent:specialist-output:v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["capability", "summary", "findings", "contradictions", "uncertainty", "materiality", "knowledge_cutoff"],
  "properties": {
    "capability": {"enum": ["filing", "news", "macro", "political", "critic"]},
    "summary": {"type": "string", "minLength": 1},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["statement", "kind", "confidence", "citations"],
        "properties": {
          "statement": {"type": "string", "minLength": 1},
          "kind": {"enum": ["fact", "inference"]},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "citations": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["evidence_id", "claim"],
              "properties": {
                "evidence_id": {"type": "string", "format": "uuid"},
                "claim": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    },
    "contradictions": {"type": "array", "items": {"type": "string"}},
    "uncertainty": {"type": "array", "items": {"type": "string"}},
    "materiality": {"enum": ["low", "medium", "high"]},
    "knowledge_cutoff": {"type": "string", "format": "date-time"}
  }
}
