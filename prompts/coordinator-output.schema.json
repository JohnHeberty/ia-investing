{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ia-investing:agent:coordinator-output:v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["plan", "specialist_outputs", "consolidated_findings", "unresolved_contradictions", "confidence", "partial_failure_capabilities"],
  "properties": {
    "plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["objective", "steps", "data_as_of", "knowledge_cutoff"],
      "properties": {
        "objective": {"type": "string", "minLength": 1},
        "steps": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["capability", "question", "required"],
            "properties": {
              "capability": {"enum": ["filing", "news", "macro", "political", "critic"]},
              "question": {"type": "string", "minLength": 1},
              "required": {"type": "boolean"}
            }
          }
        },
        "data_as_of": {"type": "string", "format": "date-time"},
        "knowledge_cutoff": {"type": "string", "format": "date-time"}
      }
    },
    "specialist_outputs": {"type": "array", "items": {"$ref": "urn:ia-investing:agent:specialist-output:v1"}},
    "consolidated_findings": {"type": "array", "items": {"type": "object"}},
    "unresolved_contradictions": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "partial_failure_capabilities": {"type": "array", "items": {"type": "string"}}
  }
}
