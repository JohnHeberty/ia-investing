    "prettier": "3.9.5",
    "typescript": "5.9.3",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "storybook": "^10.5.3",
    "@storybook/nextjs-vite": "^10.5.3",
    "@chromatic-com/storybook": "^5.2.1",
