    "@tanstack/react-table": "8.21.3",
    "echarts": "6.1.0",
    "lucide-react": "1.25.0",
    "next": "16.2.10",
    "openapi-fetch": "0.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.82.0",
