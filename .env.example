# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/stock_intelligence

# Storage (S3 / MinIO)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=raw-documents

# OpenAI API (Agents SDK)
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# LiteLLM Gateway (optional, for multi-provider routing)
LITELLM_GATEWAY_URL=http://localhost:4000/v1

# Temporal (orchestration)
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=stock-intelligence

# Observability
OTLP_ENDPOINT=http://localhost:4317
ENABLE_OTEL=true

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Application
APP_ENV=development
LOG_LEVEL=DEBUG
