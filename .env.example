# Database
DATABASE__URL=postgresql+asyncpg://postgres:postgres@localhost:5432/stock_intelligence
DATABASE__POOL_SIZE=10
DATABASE__MAX_OVERFLOW=20

# Storage (S3 / MinIO)
STORAGE__ENDPOINT=http://localhost:9000
STORAGE__ACCESS_KEY=minioadmin
STORAGE__SECRET_KEY=minioadmin
STORAGE__BUCKET=raw-documents

# OpenAI API (Agents SDK)
AI__PROVIDER=mock
AI__OPENAI_API_KEY=
AI__OPENAI_BASE_URL=https://api.openai.com/v1

# LiteLLM Gateway (optional, for multi-provider routing)
AI__LITELLM_GATEWAY_URL=http://localhost:4000/v1

# Temporal (orchestration)
TEMPORAL__ADDRESS=localhost:7233
TEMPORAL__NAMESPACE=default
TEMPORAL__TASK_QUEUE=stock-intelligence

# Schedule CVM inicial (obrigatório apenas ao reconciliar schedules)
SCHEDULER__CVM_CNPJ=
SCHEDULER__CVM_ISSUER_ID=
SCHEDULER__CVM_YEAR=2025
SCHEDULER__CVM_STATEMENT_TYPE=DRE_con

# Worker executa uma capacidade por processo
WORKER__CAPABILITY=research-agents
SCHEDULER__PAPER_PORTFOLIO_ID=
SCHEDULER__PAPER_ORGANIZATION_ID=
SCHEDULER__PAPER_PORTFOLIO_VERSION_ID=
SCHEDULER__PAPER_REBALANCE_INPUT_SHA256=
WORKER__ACTIVITY_THREADS=8

# Observability
TELEMETRY__OTLP_ENDPOINT=http://localhost:4317
TELEMETRY__ENABLED=true

# MLflow
TELEMETRY__MLFLOW_TRACKING_URI=http://localhost:5000

# OIDC (required in production)
SECURITY__OIDC_ISSUER=
SECURITY__OIDC_AUDIENCE=
SECURITY__OIDC_CLIENT_ID=
SECURITY__OIDC_JWKS_URL=

# Frontend BFF OIDC (server-only; never prefix secrets with NEXT_PUBLIC_)
OIDC_AUTHORIZATION_URL=
OIDC_TOKEN_URL=
OIDC_END_SESSION_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback
OIDC_SCOPE=openid profile email offline_access
IA_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_IA_BFF_BASE_URL=/api/backend

# Application
APPLICATION__ENVIRONMENT=development
APPLICATION__LOG_LEVEL=DEBUG
